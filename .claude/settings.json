{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(npm run lint:style)",
      "Bash(npx tsc --noEmit)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(gh issue create*)",
      "Bash(gh issue view*)",
      "Bash(gh issue comment*)",
      "Bash(gh issue edit*)",
      "Bash(gh pr create*)",
      "Bash(gh pr view*)"
    ],
    "deny": [
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(git push --force*)",
      "Bash(git push origin develop*)",
      "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$CLAUDE_PROJECT_DIR/.claude/logs\" && jq -r '\"\\(now | todate) \\(.tool_name)\"' >> \"$CLAUDE_PROJECT_DIR/.claude/logs/tool-usage.log\"",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  }
}
